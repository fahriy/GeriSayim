<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Tactical Countdown HUD</title>

<style>
:root{
  --bg:#050607;
  --green:#39ff88;
  --dim:#1a2a20;
  --warn:#ff3b3b;
}

*{box-sizing:border-box;font-family:system-ui,Segoe UI,Arial}

body{
  margin:0;
  background:radial-gradient(circle at center,#0a0f0c,#050607);
  color:var(--green);
  overflow-x:hidden;
}

/* GRID + SCAN */
body::before{
  content:"";
  position:fixed;inset:0;
  background-image:
    linear-gradient(to right, rgba(57,255,136,.05) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(57,255,136,.05) 1px, transparent 1px);
  background-size:40px 40px;
  pointer-events:none;
}

body::after{
  content:"";
  position:fixed;inset:0;
  background:linear-gradient(to bottom,transparent,rgba(57,255,136,.06),transparent);
  animation:scan 4s linear infinite;
  pointer-events:none;
}

@keyframes scan{
  0%{transform:translateY(-100%)}
  100%{transform:translateY(100%)}
}

.container{
  max-width:1100px;
  margin:40px auto;
  padding:20px;
}

.hud{
  border:1px solid rgba(57,255,136,.3);
  padding:20px;
  border-radius:12px;
  background:rgba(0,0,0,.4);
  box-shadow:0 0 25px rgba(57,255,136,.1);
}

/* TOP GRID */
.top{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:10px;
  margin-bottom:15px;
}

.mid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:10px;
  margin-bottom:20px;
}

.box{
  border:1px solid rgba(57,255,136,.25);
  padding:12px;
  text-align:center;
  background:rgba(0,0,0,.3);
}

.label{font-size:11px;opacity:.7}
.value{font-size:18px;font-weight:600;margin-top:5px}

/* CENTER */
.center{
  text-align:center;
  margin:20px 0;
}

.big{
  font-size:64px;
  letter-spacing:2px;
  font-weight:700;
  text-shadow:0 0 15px rgba(57,255,136,.4);
}

.ms{
  font-size:28px;
  opacity:.8;
}

.target{
  margin-top:10px;
  font-size:12px;
  opacity:.7;
}

/* CONTROLS */
.controls{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  justify-content:center;
  margin-top:20px;
}

input{
  padding:10px;
  background:#0b120e;
  border:1px solid rgba(57,255,136,.3);
  color:var(--green);
}

button{
  padding:10px 15px;
  background:transparent;
  border:1px solid var(--green);
  color:var(--green);
  cursor:pointer;
  transition:.2s;
}

button:hover{
  background:rgba(57,255,136,.1);
}

.danger{
  border-color:var(--warn);
  color:var(--warn);
}

/* MISSION COMPLETE */
.complete{
  color:var(--warn);
  animation:pulse 1s infinite;
}

@keyframes pulse{
  0%,100%{opacity:1}
  50%{opacity:.3}
}

/* RESPONSIVE */
@media(max-width:700px){
  .big{font-size:42px}
}
</style>
</head>

<body>

<div class="container">
  <div class="hud">

    <div class="top">
      <div class="box"><div class="label">YIL</div><div class="value" id="yil">-</div></div>
      <div class="box"><div class="label">AY</div><div class="value" id="ay">-</div></div>
    </div>

    <div class="mid">
      <div class="box"><div class="label">GÜN</div><div class="value" id="gun">-</div></div>
      <div class="box"><div class="label">SAAT</div><div class="value" id="saat">-</div></div>
      <div class="box"><div class="label">DK</div><div class="value" id="dk">-</div></div>
    </div>

    <div class="center">
      <div class="big" id="sn">00</div>
      <div class="ms" id="ms">000</div>
      <div class="target" id="targetText">HEDEF: -</div>
    </div>

    <div class="controls">
      <input type="datetime-local" id="dateInput"/>
      <button onclick="start()">START</button>
      <button onclick="stop()">STOP</button>
      <button onclick="resume()">RESUME</button>
      <button class="danger" onclick="reset()">RESET</button>
    </div>

  </div>
</div>

<script>
let targetTime = null;
let running = false;
let paused = false;
let remaining = null;

const els = {
  yil: document.getElementById("yil"),
  ay: document.getElementById("ay"),
  gun: document.getElementById("gun"),
  saat: document.getElementById("saat"),
  dk: document.getElementById("dk"),
  sn: document.getElementById("sn"),
  ms: document.getElementById("ms"),
  target: document.getElementById("targetText")
};

function save(){
  localStorage.setItem("targetTime", targetTime);
  localStorage.setItem("running", running);
  localStorage.setItem("remaining", remaining);
}

function load(){
  const t = localStorage.getItem("targetTime");
  const r = localStorage.getItem("running");
  const rem = localStorage.getItem("remaining");

  if(t){
    targetTime = parseInt(t);
    running = r === "true";
    remaining = rem ? parseInt(rem) : null;
  }
}

function format(diff){
  if(diff <= 0){
    return null;
  }

  const ms = diff % 1000;
  const totalSec = Math.floor(diff / 1000);

  const sec = totalSec % 60;
  const min = Math.floor(totalSec / 60) % 60;
  const hour = Math.floor(totalSec / 3600) % 24;
  const day = Math.floor(totalSec / 86400);
  const month = Math.floor(day / 30);
  const year = Math.floor(month / 12);

  return {year,month:month%12,day:day%30,hour,min,sec,ms};
}

function tick(){
  if(!running || !targetTime) return;

  const now = Date.now();
  const diff = targetTime - now;

  const f = format(diff);

  if(!f){
    els.sn.textContent = "00";
    els.ms.textContent = "000";
    document.body.classList.add("complete");
    els.target.textContent = "MISSION COMPLETE";
    running = false;
    save();
    return;
  }

  els.yil.textContent = f.year;
  els.ay.textContent = f.month;
  els.gun.textContent = f.day;
  els.saat.textContent = f.hour;
  els.dk.textContent = f.min;
  els.sn.textContent = String(f.sec).padStart(2,"0");
  els.ms.textContent = String(f.ms).padStart(3,"0");

  requestAnimationFrame(tick);
}

function start(){
  const val = document.getElementById("dateInput").value;
  if(!val) return;

  targetTime = new Date(val).getTime();
  running = true;
  document.body.classList.remove("complete");

  els.target.textContent = "HEDEF: " + new Date(targetTime).toLocaleString();

  save();
  tick();
}

function stop(){
  if(!running) return;
  running = false;

  remaining = targetTime - Date.now();
  save();
}

function resume(){
  if(!remaining) return;
  targetTime = Date.now() + remaining;
  running = true;

  save();
  tick();
}

function reset(){
  running = false;
  targetTime = null;
  remaining = null;

  localStorage.clear();

  els.yil.textContent = "-";
  els.ay.textContent = "-";
  els.gun.textContent = "-";
  els.saat.textContent = "-";
  els.dk.textContent = "-";
  els.sn.textContent = "00";
  els.ms.textContent = "000";
  els.target.textContent = "HEDEF: -";

  document.body.classList.remove("complete");
}

load();
if(running && targetTime) tick();
</script>

</body>
</html>
